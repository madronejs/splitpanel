{
  "name": "@madronejs/splitpanel",
  "version": "0.0.21",
  "private": false,
  "license": "MIT",
  "type": "module",
  "files": [
    "dist/*.js",
    "dist/*.mjs",
    "dist/*.css",
    "types/**/*.d.ts"
  ],
  "keywords": [
    "splitpanel",
    "splitpane",
    "panel",
    "drag",
    "draggable",
    "resizable",
    "madrone",
    "vue",
    "web components"
  ],
  "types": "types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./style": "./dist/splitpanel.css"
  },
  "scripts": {
    "dev": "vite",
    "test": "vitest",
    "lint": "eslint src/ --ext .js,.jsx,.ts,.tsx",
    "build-dev": "NODE_ENV=development pnpm build-all",
    "build-types": "rm -rf types/* && vue-tsc -p ./tsconfig.json && tsc-alias -p tsconfig.json",
    "build": "rm -rf dist/* && vite build",
    "build-all": "pnpm build-types && pnpm build",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@eslint/compat": "~1.4.0",
    "@eslint/eslintrc": "~3.3.1",
    "@eslint/js": "~9.37.0",
    "@stylistic/eslint-plugin": "~5.4.0",
    "@types/animejs": "^3.1.13",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vitejs/plugin-vue-jsx": "^5.1.1",
    "eslint": "~9.37.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-unicorn": "^61.0.2",
    "globals": "~16.4.0",
    "sass": "^1.93.2",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.9.3",
    "typescript-eslint": "8.46.1",
    "vite": "^7.1.9",
    "vitest": "^3.2.4",
    "vue-tsc": "^3.1.1"
  },
  "dependencies": {
    "drag-drop-touch": "^1.3.1",
    "lodash": "^4.17.21",
    "uuid": "^13.0.0"
  },
  "peerDependencies": {
    "@madronejs/core": "^1.0.16",
    "animejs": "^4.0.2",
    "vue": "^3.5.12"
  },
  "engines": {
    "node": ">=20.11 || >=22.14",
    "pnpm": ">= 10"
  },
  "packageManager": "pnpm@10.18.3"
}
