{
  "name": "@madronejs/splitpanel",
  "version": "0.0.23",
  "private": false,
  "license": "MIT",
  "type": "module",
  "files": [
    "dist/*.js",
    "dist/*.mjs",
    "dist/*.css",
    "types/**/*.d.ts"
  ],
  "keywords": [
    "splitpanel",
    "splitpane",
    "panel",
    "drag",
    "draggable",
    "resizable",
    "madrone",
    "vue",
    "web components"
  ],
  "types": "types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./style": "./dist/splitpanel.css"
  },
  "scripts": {
    "dev": "vite",
    "test": "vitest",
    "lint": "eslint src/ --ext .js,.jsx,.ts,.tsx",
    "build-dev": "NODE_ENV=development pnpm build-all",
    "build-types": "rm -rf types/* && vue-tsc -p ./tsconfig.json && tsc-alias -p tsconfig.json",
    "build": "rm -rf dist/* && vite build",
    "build-all": "pnpm build-types && pnpm build",
    "preview": "vite preview",
    "all": "pnpm build-types && pnpm lint && CI=true pnpm test"
  },
  "devDependencies": {
    "@eslint/compat": "~2.0.5",
    "@eslint/eslintrc": "~3.3.5",
    "@eslint/js": "~10.0.1",
    "@stylistic/eslint-plugin": "~5.10.0",
    "@types/animejs": "^3.1.13",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitejs/plugin-vue-jsx": "^5.1.4",
    "eslint": "~10.2.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "~17.5.0",
    "sass": "^1.97.3",
    "tsc-alias": "^1.8.16",
    "typescript": "^6.0.2",
    "typescript-eslint": "8.58.1",
    "vite": "^7.3.1",
    "vitest": "^4.1.4",
    "vue-tsc": "^3.2.6"
  },
  "dependencies": {
    "drag-drop-touch": "^1.3.1",
    "lodash": "^4.18.1",
    "uuid": "^13.0.0"
  },
  "peerDependencies": {
    "@madronejs/core": "^1.0.16",
    "animejs": "^4.0.2",
    "vue": "^3.5.12"
  },
  "engines": {
    "node": "^22.14 || ^24.14",
    "pnpm": ">= 10"
  },
  "packageManager": "pnpm@10.33.0",
  "comment": "overrides should be reviewed and removed when dependent packages are updated",
  "pnpm": {
    "overrides": {
      "mimimatch": ">9.0.7",
      "rollup": "4.59.0",
      "semver": ">=7.7.3"
    }
  }
}
